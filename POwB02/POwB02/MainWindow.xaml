<Window x:Class="POwB02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:local="clr-namespace:POwB02"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <!-- obrazy -->
            <RowDefinition Height="2*"/>
            <!-- histogram -->
            <RowDefinition Height="Auto"/>
            <!-- przycisk i info -->
        </Grid.RowDefinitions>

        <!-- Grid dla obrazów -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Oryginalny obraz -->
            <skia:SKElement x:Name="OriginalCanvas" Grid.Column="0" PaintSurface="OriginalCanvas_PaintSurface" Margin="5"/>
            <!-- Grayscale -->
            <skia:SKElement x:Name="GrayscaleCanvas" Grid.Column="1" PaintSurface="GrayscaleCanvas_PaintSurface" Margin="5" />
            <!-- LBP obraz -->
            <skia:SKElement x:Name="LBPCanvas" Grid.Column="2" PaintSurface="LBPCanvas_PaintSurface" Margin="5"/>
        </Grid>

        <!-- Histogram -->
        <skia:SKElement x:Name="HistogramCanvas" Grid.Row="1" PaintSurface="HistogramCanvas_PaintSurface" Margin="5"/>

        <!-- Panel przycisku i info -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <Button Content="Przetwórz bazę" Click="ProcessDatabase_Click" Width="120" Height="30" Margin="10"/>
            <Button Content="Wczytaj obraz" Click="LoadImage_Click" Width="120" Height="30" Margin="0,0,10,0"/>
            <TextBlock x:Name="InfoTextBlock" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
