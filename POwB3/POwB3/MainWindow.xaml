<Window x:Class="POwB3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POwB3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnLoad" Content="Wczytaj obraz" 
                        Width="130" Height="35" Click="BtnLoad_Click"
                        Background="#E1E4E8" BorderThickness="0" Cursor="Hand"/>

                <Separator Width="2" Margin="20,5" Background="#EEE"/>

                <StackPanel Margin="10,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="liczba klastrów (k):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="SliderK" Minimum="2" Maximum="20" Value="3" Width="120" 
                                VerticalAlignment="Center" IsSnapToTickEnabled="True" TickPlacement="BottomRight"/>
                        <TextBlock Text="{Binding ElementName=SliderK, Path=Value}" FontWeight="Bold" 
                                   Width="30" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#007ACC"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="10,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="maksymalna liczba iteracji:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtIterations" Text="10" Width="70" Height="28" 
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                             BorderBrush="#DDD" BorderThickness="1"/>
                </StackPanel>

                <Button x:Name="BtnStart" Content="segmentacja" 
                        Background="#007ACC" Foreground="White" FontWeight="Bold"
                        Padding="20,0" Height="40" Margin="30,0,0,0" Click="BtnStart_Click"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Oryginał" Grid.Column="0" Margin="0,0,10,0" Padding="5">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImgOriginal" Stretch="Uniform"/>
                </ScrollViewer>
            </GroupBox>

            <GroupBox Header="Wynik" Grid.Column="1" Margin="10,0,0,0" Padding="5">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImgResult" Stretch="Uniform"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="2" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Gotowy" Foreground="#888" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="ProgressB" Width="200" Height="10" Visibility="Collapsed" IsIndeterminate="True"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
